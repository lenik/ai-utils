#!/bin/sh
# master-file
# Enable and start aifmt (binfmt_misc for AI scripts) via systemd.

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload
    systemctl enable aifmt.service
    systemctl start aifmt.service
else
    echo "systemd not found; aifmt.service was not enabled. Run @pkgdatadir@/aifmt start manually if needed." >&2
fi

exit 0
